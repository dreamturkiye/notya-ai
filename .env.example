# ============================================================
# NOTYA AI - Ortam Değişkenleri
# Tüm değişkenleri .env.local dosyasına kopyalayın
# ============================================================

# ---- UYGULAMA ----
NEXT_PUBLIC_APP_URL=https://notya.ai
NODE_ENV=production

# ---- SUPABASE (EU Frankfurt) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- ANTHROPIC (Claude API) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- DEEPGRAM (Türkçe Transkripsiyon) ----
DEEPGRAM_API_KEY=...
DEEPGRAM_PROJECT_ID=...

# ---- GÜVENLİK / ŞİFRELEME ----
# KVKK: Hasta kişisel verilerini şifrelemek için (min 32 karakter)
ENCRYPTION_MASTER_KEY=notya-kvkk-encryption-key-2026-secure-random
ENCRYPTION_SALT=notya-ai-kvkk-salt-2026
TC_HASH_PEPPER=notya-tc-kimlik-pepper-gizli-2026

# ---- İYZİCO (Türk Ödeme Sistemi) ----
IYZICO_API_KEY=sandbox-...
IYZICO_SECRET_KEY=sandbox-...
IYZICO_BASE_URL=https://api.iyzipay.com
# Plan kodları
IYZICO_PLAN_STARTER_MONTHLY=notya-starter-monthly
IYZICO_PLAN_STARTER_YEARLY=notya-starter-yearly
IYZICO_PLAN_PRO_MONTHLY=notya-pro-monthly
IYZICO_PLAN_PRO_YEARLY=notya-pro-yearly
IYZICO_PLAN_KLINIK_MONTHLY=notya-klinik-monthly
IYZICO_PLAN_KLINIK_YEARLY=notya-klinik-yearly

# ---- WHATSAPP BUSINESS API ----
WHATSAPP_ACCESS_TOKEN=EAAx...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_BUSINESS_ACCOUNT_ID=...
WHATSAPP_VERIFY_TOKEN=notya-whatsapp-verify-2026

# ---- RESEND (E-posta) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=merhaba@notya.ai
RESEND_FROM_NAME=Notya AI

# ---- TELEGRAM (Admin Bildirimler) ----
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ADMIN_CHAT_ID=5545242725

# ---- UPSTASH REDIS (Önbellek) ----
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ---- RATE LİMİT ----
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
